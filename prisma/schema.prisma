generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Thread {
  id        String   @id @default(cuid())
  title     String
  content   String
  author    String
  category  String
  createdAt DateTime @default(now())
  replies   Reply[]
}

model Reply {
  id          String   @id @default(cuid())
  content     String
  author      String
  isPengasuh  Boolean  @default(false)
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
  threadId    String
  thread      Thread   @relation(fields: [threadId], references: [id])
}
