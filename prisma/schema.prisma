generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Thread {
  id          String   @id @default(cuid())
  title       String
  content     String
  author      String // nama yang ditampilkan ke publik ("Anonim" jika anonim)
  authorReal  String? // identitas asli, hanya untuk admin/Pengasuh
  isAnonymous Boolean  @default(false)
  category    String
  isRead      Boolean  @default(false) // sudah dibuka/dibaca admin
  isAnswered  Boolean  @default(false) // sudah dijawab Pengasuh
  createdAt   DateTime @default(now())
  replies     Reply[]
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Reply {
  id          String   @id @default(cuid())
  content     String
  author      String // nama yang ditampilkan ke publik ("Anonim" jika anonim)
  authorReal  String? // identitas asli, hanya untuk admin/Pengasuh
  isAnonymous Boolean  @default(false)
  isPengasuh  Boolean  @default(false)
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
  threadId    String
  thread      Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AnonymousReport {
  id          String   @id @default(cuid())
  subject     String
  description String
  location    String?
  dateOccurred String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Materi {
  id           String   @id
  nomor        Int
  judul        String
  ringkasan    String
  poinKunci    String[]
  kutipanPasal Json[]
  praktikBaik  String[]
  pelanggaran  String[]
  icon         String
}

model StudiKasus {
  id              String   @id
  nomor           Int
  judul           String
  situasi         String
  pilihan         Json[] 
  umpanBalikBenar String
  pelajaranUtama  String
  rujukanPasal    String
}

model Kuis {
  id           Int      @id @default(autoincrement())
  pertanyaan   String
  pilihan      Json[] 
  jawabanBenar String
  penjelasan   String
  rujukanPasal String
}

enum Role {
  TARUNA
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  npm       String   @unique
  name      String
  password  String
  points    Int      @default(0)
  role      Role     @default(TARUNA)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  threads       Thread[]
  replies       Reply[]
  quizAttempts  QuizAttempt[]
}

model QuizAttempt {
  id        String   @id @default(cuid())
  score     Int
  total     Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

